/* ===== 全局 ===== */
QMainWindow, QWidget {
    background-color: #f5f6fa;
    font-family: &quot;Microsoft YaHei&quot;, &quot;Segoe UI&quot;, Arial;
    font-size: 13px;
    color: #2c3e50;
}

/* ===== 顶部导航栏 ===== */
QWidget#topBar {
    background-color: #ffffff;
    border-bottom: 2px solid #e8ecf1;
    padding: 0px;
}
QWidget#topBar QLabel#titleLabel {
    font-size: 20px;
    font-weight: bold;
    color: #1a73e8;
    padding-left: 8px;
}

/* ===== 按钮 ===== */
QPushButton {
    background-color: #ffffff;
    border: 1px solid #d1d9e6;
    border-radius: 6px;
    padding: 7px 18px;
    font-size: 13px;
    color: #2c3e50;
    min-height: 18px;
}
QPushButton:hover {
    background-color: #e8f0fe;
    border-color: #1a73e8;
    color: #1a73e8;
}
QPushButton:pressed {
    background-color: #d2e3fc;
}
QPushButton:disabled {
    background-color: #f0f0f0;
    color: #b0b0b0;
    border-color: #e0e0e0;
}

/* 主操作按钮（开始） */
QPushButton#pushButton_3 {
    background-color: #1a73e8;
    color: #ffffff;
    border: none;
    font-weight: bold;
    padding: 8px 28px;
    border-radius: 6px;
}
QPushButton#pushButton_3:hover {
    background-color: #1557b0;
}
QPushButton#pushButton_3:pressed {
    background-color: #0d47a1;
}

/* 危险操作按钮（结束） */
QPushButton#pushButton_7 {
    background-color: #ffffff;
    color: #d93025;
    border: 1px solid #d93025;
    font-weight: bold;
    padding: 8px 28px;
    border-radius: 6px;
}
QPushButton#pushButton_7:hover {
    background-color: #fce8e6;
}

/* ===== 输入框 ===== */
QLineEdit {
    background-color: #ffffff;
    border: 1px solid #d1d9e6;
    border-radius: 6px;
    padding: 6px 12px;
    color: #2c3e50;
    selection-background-color: #1a73e8;
    selection-color: #ffffff;
}
QLineEdit:focus {
    border: 2px solid #1a73e8;
}
QLineEdit:disabled {
    background-color: #f0f0f0;
    color: #999999;
}

/* ===== 分组框 ===== */
QGroupBox {
    font-weight: bold;
    font-size: 13px;
    color: #34495e;
    border: 1px solid #d1d9e6;
    border-radius: 8px;
    margin-top: 14px;
    padding: 14px 12px 12px 12px;
    background-color: #ffffff;
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 16px;
    padding: 0 8px;
    color: #1a73e8;
}

/* ===== 表格 ===== */
QTableWidget {
    background-color: #ffffff;
    alternate-background-color: #f5f7fa;
    border: 1px solid #d1d9e6;
    border-radius: 6px;
    gridline-color: #e8ecf1;
    selection-background-color: #d2e3fc;
    selection-color: #1a1a1a;
    font-size: 12px;
}
QTableWidget::item {
    padding: 4px 8px;
}
QHeaderView::section {
    background-color: #f0f3f7;
    padding: 6px 8px;
    border: none;
    border-right: 1px solid #d1d9e6;
    border-bottom: 2px solid #1a73e8;
    font-weight: bold;
    font-size: 12px;
    color: #34495e;
}

/* ===== 复选框 ===== */
QCheckBox {
    spacing: 8px;
    font-size: 13px;
    color: #2c3e50;
}
QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border-radius: 4px;
    border: 2px solid #b0bec5;
    background-color: #ffffff;
}
QCheckBox::indicator:hover {
    border-color: #1a73e8;
}
QCheckBox::indicator:checked {
    background-color: #1a73e8;
    border-color: #1a73e8;
    image: url();
}

/* ===== 标签 ===== */
QLabel#label_imagePreview {
    background-color: #2c3e50;
    border: 2px dashed #d1d9e6;
    border-radius: 8px;
    color: #95a5a6;
    font-size: 14px;
}

/* ===== 状态栏 ===== */
QStatusBar {
    background-color: #ffffff;
    border-top: 1px solid #e8ecf1;
    color: #5f6368;
    font-size: 12px;
}

/* ===== 菜单栏 ===== */
QMenuBar {
    background-color: #ffffff;
    border-bottom: 1px solid #e8ecf1;
    color: #2c3e50;
    font-size: 13px;
}
QMenuBar::item:selected {
    background-color: #e8f0fe;
}
QMenu {
    background-color: #ffffff;
    border: 1px solid #d1d9e6;
    border-radius: 6px;
}
QMenu::item:selected {
    background-color: #e8f0fe;
}
